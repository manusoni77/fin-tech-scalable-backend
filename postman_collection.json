{
  "info": {
    "name": "Fintech Wallet API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"John Doe\", \"email\": \"john@test.com\", \"password\": \"Pass@1234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"john@test.com\", \"password\": \"Pass@1234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"admin@fintech.com\", \"password\": \"Admin@1234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('admin_token', json.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get My Wallet",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/wallet",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Deposit",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/wallet/deposit",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 1000, \"description\": \"Initial deposit\"}"
            }
          }
        },
        {
          "name": "Withdraw",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/wallet/withdraw",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 200, \"description\": \"ATM withdrawal\"}"
            }
          }
        },
        {
          "name": "Transfer",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/wallet/transfer",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"to_wallet_id\": 2, \"amount\": 100, \"description\": \"Payment\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "History - All",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/transactions?page=1&limit=10&sort=desc",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "History - Filter by Type",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/transactions?type=deposit&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "type", "value": "deposit" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "History - Filter by Date Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/transactions?from=2024-01-01&to=2024-12-31&page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "transactions"],
              "query": [
                { "key": "from", "value": "2024-01-01" },
                { "key": "to", "value": "2024-12-31" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/users?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Delete User (Soft)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/admin/users/2",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "List Wallets",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/wallets?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "wallets"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/admin/transactions?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "transactions"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          }
        },
        {
          "name": "Bulk Upload Transactions (CSV)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/admin/transactions/bulk",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "transactions.csv",
                  "description": "CSV: wallet_id,type,amount,description"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
